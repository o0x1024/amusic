{
  "name": "amusic",
  "version": "0.1.0",
  "type": "module",
  "description": "桌面版 AI 音乐创作提示词工作台",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:mac": "npm run build && electron-builder --mac zip --arm64",
    "dist:win": "npm run build && electron-builder --win nsis --x64 && electron-builder --win portable --x64",
    "dist": "npm run dist:mac && npm run dist:win",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "10.4.20",
    "daisyui": "4.12.24",
    "electron-vite": "^4.0.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "^5.7.3",
    "vue": "^3.5.13"
  },
  "build": {
    "appId": "com.amusic.app",
    "productName": "amusic",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "out/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  }
}
