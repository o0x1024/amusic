{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch amusic",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "amusic",
        "order": 1
      }
    }
  ]
}
